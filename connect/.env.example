PORT=3000
DATABASE_URL=postgres://mvpn:mvpn@localhost:5432/mvpn?sslmode=disable

# Internal token sent to the api as X-Internal-Token for /internal/provision
# (and to authenticate connect's own /admin/configs). MUST equal the api's
# INTERNAL_TOKEN_CONNECT (or its ADMIN_TOKEN fallback).
ADMIN_TOKEN=change_me_to_random_secret

# api base URL for per-device provisioning (same docker network).
API_INTERNAL_URL=http://api:8081

# Subscription metadata (shown in Happ / v2RayTun / V2Box)
PROFILE_TITLE=mvp-n
UPDATE_HOURS=12
SUPPORT_URL=https://t.me/mvp_n_net_bot
