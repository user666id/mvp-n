PORT=8081
DATABASE_URL=postgres://mvpn:mvpn@localhost:5432/mvpn?sslmode=disable
JWT_SECRET=change_me_to_random_32_chars_minimum
# Optional: previous JWT secret, accepted verify-only during a rotation window
# so rotating JWT_SECRET doesn't invalidate active sessions. Clear after 30 days.
JWT_SECRET_PREVIOUS=
BOT_TOKEN=your_telegram_bot_token

# Comma-separated Telegram IDs of admins.
# The FIRST id is seeded as internal_id=1.
ADMIN_TG_IDS=123456789

# Per-service internal tokens (X-Internal-Token). Each caller gets its own
# secret. Both fall back to ADMIN_TOKEN below when unset.
INTERNAL_TOKEN_CONNECT=
INTERNAL_TOKEN_BOT=
# Legacy shared internal secret (fallback for the two tokens above).
ADMIN_TOKEN=

AWG_API_URL=http://127.0.0.1:8080
AWG_API_TOKEN=

XRAY_API_HOST=127.0.0.1
XRAY_API_PORT=10085
CONNECT_URL=http://127.0.0.1:3000

# Network interface for server_metrics. Auto-detect if empty.
NET_INTERFACE=
