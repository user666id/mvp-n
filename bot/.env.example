# Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token

# Mini App URL — must match the path nginx serves it from.
MINI_APP_URL=https://app.mvp-n.net/v2/

# Optional: read the user's in-app language so greetings match the Mini App.
# If unset/unreachable the bot falls back to the Telegram language_code.
API_INTERNAL_URL=http://api:8081
# Internal token sent as X-Internal-Token for GET /internal/user-lang. MUST
# equal the api's INTERNAL_TOKEN_BOT (or its ADMIN_TOKEN fallback).
ADMIN_TOKEN=
