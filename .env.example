# ─────────────────────────────────────────────────────────────────────────────
# mvp-n — root environment for docker-compose.yml
#
#   cp .env.example .env   &&   nano .env   &&   docker compose up -d --build
#
# Every variable below is read by docker-compose.yml. Required ones are marked
# REQUIRED — the stack refuses to start without them.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED. Password for the bundled PostgreSQL. Pick any strong random string:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# ── Auth / API ───────────────────────────────────────────────────────────────
# REQUIRED. Secret for signing JWTs (≥32 chars). Generate:
#   openssl rand -hex 32
JWT_SECRET=

# REQUIRED. Telegram bot token from @BotFather.
BOT_TOKEN=

# REQUIRED. Comma-separated Telegram user IDs of admins (get yours from @userinfobot).
# The FIRST id is seeded as internal_id=1.
ADMIN_TG_IDS=123456789

# Shared secret for the internal provisioning endpoint (connect → api).
# Generate:  openssl rand -hex 24
CONNECT_ADMIN_TOKEN=

# ── AmneziaWG ────────────────────────────────────────────────────────────────
# REQUIRED. Bearer token for the awg-server API. Must match what
# scripts/install/amneziawg.sh writes. Generate:  openssl rand -hex 24
AWG_API_TOKEN=

# ── Xray REALITY (baked into the VLESS link by the API) ──────────────────────
# Public IPv4 of this server (the port is fixed: :43000 / :43001).
SERVER_IP=

# REALITY keypair public half + short id. Produced by scripts/install/xray.sh
# (or:  xray x25519  for the key,  openssl rand -hex 8  for the short id).
# If empty, issued links get an empty pbk/sid and clients fail with "empty password".
XRAY_PUBLIC_KEY=
XRAY_SHORT_ID=

# ── Subscription / bot metadata (optional, sane defaults) ────────────────────
PROFILE_TITLE=mvp-n
SUPPORT_URL=https://t.me/your_bot
# Mini App URL — must match the path nginx serves the built frontend from.
MINI_APP_URL=https://app.example.com/v2/
